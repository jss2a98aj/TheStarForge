{
  "itemName": "starforge-unboundshotgun",
  "price": 500,
  "maxStack": 1,
  "rarity": "Legendary",
  "description": "A pump shotgun commonly used in urban combat, loaded with deadly incendiary shells.",
  "shortdescription": "\"Salamander\" SG",
  "tooltipKind": "starforge-uniquegun",
  "category": "uniqueWeapon",
  "tooltipFieldsOverride" : {"subtitle":"Pump Shotgun"},
  "twoHanded": true,
  "level" : 6,
  "itemTags": [ "weapon", "ranged", "shotgun" ],
  "manufacturer" : "unboundarmaments",
  "inventoryIcon": "unboundshotgun.png:idle",

  "animation" : "/items/active/weapons/ranged/animations/starforge-shellanimgun.animation",
  "animationParts": {
    "butt": "",
    "middle": "unboundshotgun.png",
    "barrel": "",
    "middleFullbright": "unboundshotgunfullbright.png",
    "muzzleFlash": "/items/active/weapons/ranged/muzzleflash/starforge-firemuzzleflash.png"
  },
  "animationCustom": {
    "animatedParts" : {
      "stateTypes" : {
        "gun" : {
          "states" : {
            "reload" : {
              "properties" : {
                "immediateSound" : "/sfx/gun/reload/shotgun_reload_clip3.ogg"
              }
            }
          }
        }
      },
      "parts" : {
        "middleFullbright" : {
          "properties" : {
            "offset" : [0.625, -0.250]
          }
        }
      }
    },
    "particleEmitters": {
      "casing": {
        "particles": [
          { "particle": "starforge-unboundfireshell"}
        ]
      },
      "ammoIndicator" : {
        "active" : false,
        "emissionRate" : 8,
        "transformationGroups" : ["muzzle"],
        "offsetRegion" : [0, 0, 0, 0],
        "particles" : [
          { "particle" : "starforge-smallfireflame"}
        ]
      }
    },
    "lights" : {
      "flashlightSpread" : {
        "active" : true,
        "position" : [-0.75, -0.5],
        "transformationGroups" : ["muzzle"],
        "color" : [125, 125, 125],
        "pointLight" : true,
        "pointBeam" : 1
      },
      "flashlight" : {
        "active" : true,
        "position" : [-1.25, -0.5],
        "transformationGroups" : ["muzzle"],
        "color" : [200, 200, 200],
        "pointLight" : true,
        "pointAngle" : 0.00,
        "pointBeam" : 100
      }
    },
    "sounds": {
      "fire" : [ "/sfx/gun/shotgun3.ogg" ],
      "loadAmmo" : [ "/sfx/gun/reload/shotgun_reload_clip2.ogg" ]
    }
  },
  
  "baseOffset": [0.625, -0.250],
  "muzzleOffset": [2, 0.375],
  "scripts": [ "/items/active/weapons/ranged/starforge-gun.lua" ],
  "elementalType": "fire",

  "primaryAbility": {
    "scripts" : ["/items/active/weapons/ranged/starforge-gunfire.lua"],
    "class" : "StarforgeGunFire",

    "fireTime": 0.95,
    "baseDps": 12,
    "energyUsage": 45,
    "inaccuracy": 0.05,
    "projectileCount": 4,
    "fireType": "auto",
    "projectileType": "starforge-firebullet",
    "projectileParameters": {
      "knockback": 8,
      "speed" : [155, 175]
    },

    "stances": {
      "idle": {
        "armRotation": 0,
        "weaponRotation": 0,
        "weaponOffset" : [0, 0],
        "twoHanded": true,
        "allowRotate": true,
        "allowFlip": true,
        "frontArmFrame": "jump.1",
        "backArmFrame": "rotation"
      },
      "fire" : {
        "duration" : 0.3,
        "armRotation" : 4,
        "weaponRotation" : 8,
        "weaponOffset" : [0, 0.125],
        "weaponRotationCenter" : [-1, 0],
        "twoHanded" : true,

        "allowRotate" : true,
        "allowFlip" : true,
        "frontArmFrame": "jump.1",
        "backArmFrame": "rotation"
      },
      "cooldown" : {
        "duration" : 0.45,
        "armRotation" : -15,
        "weaponRotation" : 25,
        "weaponOffset" : [-0.125, 0.25],
        "weaponRotationCenter" : [-1, 0],
        "twoHanded" : true,
        "burstParticleEmitters": [ "casing" ],
        "animationStates": {
          "gun" : "reload"
        },

        "allowRotate" : true,
        "allowFlip" : true,
        "frontArmFrame": "jump.1",
        "backArmFrame": "rotation"
      }
    }
  },

  "altAbility": {
    "name" : "Load Thermite",
    "scripts" : ["/items/active/weapons/ranged/abilities/loadalternateammo/starforge-loadalternateammo.lua"],
    "class" : "StarForgeLoadAlternateAmmo",

    "swapOnCooldown" : 0.5,
    "swapOffCooldown" : 2,
    
    "adaptedAbilityIndex" : 1, //Which ability to adapt (1 = primary, 2 = secondary)
    
    //The new stats which will overwrite the primary ability
    "newAbility" : {
      "projectileParameters" : {
        "knockback": 15,
        "speed" : [125, 155]
      },
      
      "projectileCount" : 7,

      "projectileType" : "starforge-firefluxboltstatus",
      
      "fireType" : "auto",
	
      "baseDps" : 10.0,	
      "fireTime" : 1.65,
      "energyUsage" : 55,
      "inaccuracy": 0.04
    },

    "stances" : {
      "load" : {
        "duration" : 0.2,
        "aimAngle" : 0,
        "weaponAngularVelocity" : -150,
        "armAngularVelocity" : 100,
        "armRotation": 0,
        "weaponRotation": 0,
        "weaponOffset" : [0, 0],
        "twoHanded": true,
        "allowRotate": true,
        "allowFlip": true,
        "burstParticleEmitters": [ "casing" ],
        "animationStates": {
          "gun" : "reload"
        },

        "frontArmFrame": "jump.1",
        "backArmFrame": "rotation"
      }
    }
  },

  "builder" : "/items/buildscripts/starforge-builduniqueweapon.lua"
}