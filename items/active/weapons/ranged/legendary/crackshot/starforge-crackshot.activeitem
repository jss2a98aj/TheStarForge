  },
  "animationCustom": {
    "animatedParts" : {
      "stateTypes" : {
        "altSwoosh" : {
          "default" : "idle",
          "states" : {
            "idle" : {
            },
            "fire" : {
              "frames" : 3,
              "cycle" : 0.08,
              "mode" : "transition",
              "transition" : "idle"
            }
          }
        },
        "gun" : {
          "default" : "idle",
          "states" : {
            "idle" : {},
            "reload" : {
              "frames" : 2,
              "cycle" : 0.2,
              "mode" : "transition",
              "transition" : "idle"
            }
          }
        }
      },

      "parts" : {
        "middleFullbright" : {
          "properties" : {
            "offset" : [1.25, 0.25]
          }
        },
        "middle" : {
          "properties" : {
            "centered" : true,
            "offset" : [0, 0], // x offset is set dynamically
            "transformationGroups" : ["weapon"]
          },

          "partStates" : {
            "gun" : {
              "idle" : {
                "properties" : {
                  "image" : "<partImage>:idle"
                }
              },
              "reload" : {
                "properties" : {
                  "image" : "<partImage>:reload.<frame>"
                }
              }
            }
          }
        },
        "altSwoosh" : {
          "properties" : {
            "zLevel" : -3,
