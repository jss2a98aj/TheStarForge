            "offset" : [1.25, -0.75],
            "transformationGroups" : ["weapon", "swoosh"]
          },
          "partStates" : {
            "altSwoosh" : {
              "idle" : {
                "properties" : {
                  "image" : ""
                }
              },
              "fire" : {
                "properties" : {
                  "image" : "/items/active/weapons/melee/swoosh/starforge/jab/jab-physical.png:<frame>",
                  "damageArea" : [[-1.5, 0], [-1, 1], [1, 1], [1, 0], [1, -1], [-1, -1]]
                }
              }
            }
          }
        }
      }
    },
    "transformationGroups" : {
      "swoosh" : {}
    },
    "particleEmitters" : {
      "muzzleFlash" : {
        "transformationGroups" : ["muzzle"],
		    "offsetRegion" : [-2.125, 0.125, -2.125, 0.125],
