        "transformationGroups" : ["swoosh"],
        "offsetRegion" : [0.0, 0.0, 0.0, 0.0],
        "particles" : []
      }
    },
    "sounds": {
  	  "altFire" : [ "/sfx/melee/swing_hammer.ogg" ],
      "fire": [ "/sfx/gun/starforge-silverserpentfire.ogg" ]
    }
  },
  
  "baseOffset" : [1.25, 0.25],
  "muzzleOffset": [1.25, 0.25],
  
  "scripts": [ "/items/active/weapons/ranged/starforge-gun.lua" ],
