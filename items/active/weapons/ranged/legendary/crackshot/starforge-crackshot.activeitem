  "tooltipKind": "starforge-uniquegun",
  "category": "uniqueWeapon",
  "tooltipFieldsOverride" : {
    "subtitle" : "Shotgun"
  },
  "twoHanded": true,
  "level" :  6,
  "fixedLevel" : false,
  "itemTags" : [ "starforge", "weapon", "ranged", "shotgun" ],
  "inventoryIcon": "starforge-crackshot.png:idle",
  
  "animation": "/items/active/weapons/ranged/starforge-gun.animation",
  "animationParts": {
