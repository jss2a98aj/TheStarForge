{
  "animatedParts" : {
    "stateTypes" : {
      "activeState" : {
        "default" : "active",
        "states" : {
          "active" : {
            "frames" : 1,
            "properties" : {
              "particleEmittersOn" : [ "idleTelegraph" ]
            }
          },
          "inactive" : {
            "frames" : 1,
            "properties" : {
              "particleEmittersOff" : [ "idleTelegraph" ]
            }
          },
          "regrow" : {
            "frames" : 5,
            "cycle" : 0.5,
            "mode" : "transition",
            "transition" : "active",
            "properties" : {
              "particleEmittersOff" : [ "idleTelegraph" ]
            }
          }
        }
      }
    },

    "parts" : {
      "base" : {
        "properties" : {
          "transformationGroups" : ["body"],
          "offset" : [1.5, 1],
          "centered" : true,
          "rotationCentre" : [0, 0]
        },

        "partStates" : {
          "activeState" : {
            "active" : {
              "properties" : {
                "image" : "<partImage>:<variant>.active"
              }
            },

            "inactive" : {
              "properties" : {
                "image" : "<partImage>:<variant>.inactive"
              }
            },

            "regrow" : {
              "properties" : {
                "image" : "<partImage>:<variant>.regrow.<frame>"
              }
            }
          }
        }
      },
      "baseFullbright" : {
        "properties" : {
          "zLevel" : 1,
          "fullbright" : true,
          "transformationGroups" : ["body"],
          "offset" : [1.5, 1],
          "centered" : true
        },

        "partStates" : {
          "activeState" : {
            "active" : {
              "properties" : {
                "image" : "<partImage>:<variant>.active"
              }
            },

            "inactive" : {
              "properties" : {
                "image" : "<partImage>:<variant>.inactive"
              }
            },

            "regrow" : {
              "properties" : {
                "image" : "<partImage>:<variant>.regrow.<frame>"
              }
            }
          }
        }
      }
    }
  },

  "transformationGroups" : {
    "body" : {}
  },

  "particleEmitters" : {
    "idleTelegraph" : {
      "active" : false,
      "offsetRegion" : [0.5, 0.5, 2.5, 1.5],
      "particles" : [
        { "particle" : {
          "type" : "ember",
          "size" : 1.0,
          "color" : [55, 71, 41, 255],
          "light" : [55, 71, 41, 255],
          "fade" : 0.9,
          "initialVelocity" : [0.0, -1],
          "finalVelocity" : [0.0, -20],
          "approach" : [0, 5],
          "timeToLive" : 0.75,
          "collidesForeground" : true,
          "layer" : "front"
        } }
      ]
    },
    "burst" : {
      "active" : false,
      "offsetRegion" : [0.5, 1, 3.5, 1],
      "particles" : []
    },
    "takeDamage" : {
      "active" : false,
      "offsetRegion" : [0.5, 1, 3.5, 1],
      "particles" : []
    }
  },

  "sounds" : {
    "burst" : [ "/sfx/gun/grenadeblast_poison1.ogg", "/sfx/gun/grenadeblast_poison2.ogg", "/sfx/gun/grenadeblast_poison3.ogg" ],
    "proximitySound" : [ "/sfx/npc/monsters/orbide_creepy_loop.ogg" ],
    "takeDamage" : []
  }
}
