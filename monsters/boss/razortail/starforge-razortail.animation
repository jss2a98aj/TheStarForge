{
  "globalTagDefaults" : {
  },

  "animatedParts" : {
    "stateTypes" : {
	    //BODY
      "body" : {
        "priority" : 1,
        "default" : "idle",
        "states" : {
          "invisible" : {
            "frames" : 1
          },
          "idle" : {
            "frames" : 1
          },
          "walk" : {
            "frames" : 8,
            "cycle" : 0.8,
            "mode" : "loop"
          },
          "jumping" : {
            "frames" : 1
          },
          "falling" : {
            "frames" : 1
          },
          "tailStrike" : {
            "frames" : 5,
            "cycle" : 0.4,
            "mode" : "transition",
            "transition" : "tailStrikeWinddown"
          },
          "tailStrikeWinddown" : {
            "frames" : 5,
            "cycle" : 0.6,
            "mode" : "transition",
            "transition" : "idle"
          }
        }
      }
    },

    "parts" : {
